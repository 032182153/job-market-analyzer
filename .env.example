# --- Database ---
# Local: postgresql://postgres:password@localhost:5432/job_trends
# Production: Your Railway/PostgreSQL URL
DATABASE_URL=postgresql://user:password@host:port/dbname

# --- Adzuna API ---
# Get keys at https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
ADZUNA_COUNTRY=us

# --- Frontend ---
# The URL of your deployed FastAPI backend
VITE_API_URL=https://your-api-hostname.railway.app

# --- Backend Settings ---
DB_NAME=job_trends
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
LOG_FILE=scraper.log
